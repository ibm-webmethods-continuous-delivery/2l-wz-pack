# User MUST provide

# WZP_HOST_MSR_LICENSE_FILE_LOCATION=c:\path\to\msr-license.xml

WZP_DEV_CONTAINER_IMAGE=ibmwebmethods.azurecr.io/webmethods-microservicesruntime
WZP_DEV_CONTAINER_TAG=11.1.0.9

WZP_DEV_UM_CONTAINER_IMAGE=ibmwebmethods.azurecr.io/universalmessaging-server
WZP_DEV_UM_CONTAINER_TAG=11.1.3

WZP_GUEST_PACKAGES_FOLDER=/opt/softwareag/IntegrationServer/packages

WZP_GUEST_MOUNT_POINT_APPLICATION_PROPERTIES=/mnt/application.properties
# WZP_GUEST_MOUNT_POINT_LICENSE_FILE=/mnt/msr-license.xml

WZP_GUEST_MOUNT_POINT_UM_REALM_DATA=/opt/softwareag/UniversalMessaging/server/umserver/data/
WZP_GUEST_MOUNT_POINT_UM_REALM_LICENSE_FOLDER=/opt/softwareag/UniversalMessaging/server/umserver/licence/
WZP_GUEST_MOUNT_POINT_UM_REALM_LOGS=/opt/softwareag/UniversalMessaging/server/umserver/logs/
WZP_GUEST_MOUNT_POINT_UM_REALM_USERS=/opt/softwareag/common/conf/

WZP_PORT_PREFIX=401

IS_ADMIN_PWD=NotManage
