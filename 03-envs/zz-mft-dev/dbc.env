# Variables that are only pertinent to the dbc service AND are not secrets

## choose what components to install on the main database
WZP_WM_DB_COMPONENTS=all

## choose what components to install on the archive database

# WZP_WM_ARCHIVE_DB_COMPONENTS=all
WZP_WM_ARCHIVE_DB_COMPONENTS=ActiveTransferArchive,ComponentTracker,TaskArchive
